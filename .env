# --- Database (SQLite, zero-config) ---
DATABASE_URL="file:./dev.db"

# --- ESG Copilot AI (Ollama, no API key required) ---
# EcoSphere talks to a local Ollama runtime. gpt-oss:120b-cloud runs the heavy
# reasoning via Ollama's cloud passthrough, so no GPU is needed locally.
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="gpt-oss:120b-cloud"
# Smaller fallback model used automatically if the primary is unavailable.
OLLAMA_FALLBACK_MODEL="gpt-oss:20b-cloud"
