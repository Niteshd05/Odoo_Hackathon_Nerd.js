# Copy this file to `.env` and adjust if needed. No secret keys are required.

# SQLite database file (created by `npm run db:reset`).
DATABASE_URL="file:./dev.db"

# EcoSphere's ESG Copilot uses Ollama instead of a paid API.
# Install Ollama (https://ollama.com), then: `ollama pull gpt-oss:120b-cloud`.
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="gpt-oss:120b-cloud"
OLLAMA_FALLBACK_MODEL="gpt-oss:20b-cloud"
